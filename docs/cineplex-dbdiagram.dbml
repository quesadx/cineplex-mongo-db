

Table cadenas [note: "Aquí guardamos la información principal de las grandes cadenas de cines.", headerColor: #1E3A58] {
  _id                ObjectId [pk]
  nombre             String   [not null]
  pais               String
  ciudad_principal   String
  ano_fundacion      Int
  cantidad_complejos Int
}

Table complejos [note: "Estos son los cines físicos concretos que pertenecen a cada cadena en distintas ciudades y distritos.", headerColor: #A63F35] {
  _id              ObjectId [pk]
  nombre           String   [not null]
  cadena_id        ObjectId [ref: > cadenas._id]
  ciudad           String
  distrito         String
  direccion        String
  telefono         String
  cantidad_salas   Int
  estacionamiento  Boolean
}

Table salas [note: "Cada cine tiene varias salas con distintas características, pantallas y sistemas de sonido.", headerColor: #3A3F4B] {
  _id           ObjectId [pk]
  numero_sala   Int      [not null]
  complejo_id   ObjectId [ref: > complejos._id]
  capacidad     Int
  tipo_pantalla String   [note: "Puede ser una pantalla Estándar, 3D, IMAX, entre otras opciones."]
  audio         String   [note: "Por ejemplo, un sonido increíble con Dolby Atmos o el clásico Dolby Digital."]
  disponible    Boolean
}

Table peliculas [note: "Nuestro catálogo completo de películas, con toda la información sobre géneros, directores y sinopsis.", headerColor: #D6A541] {
  _id              ObjectId [pk]
  titulo           String   [not null]
  director         String
  genero           String
  ano_estreno      Int
  duracion_minutos Int
  clasificacion    String
  sinopsis         String
  idioma_original  String
  en_cartelera     Boolean
}


Table funciones [note: "Las funciones o proyecciones que se planean para la semana con control de disponibilidad de asientos.", headerColor: #C84630] {
  _id          ObjectId [pk]
  pelicula_id  ObjectId [ref: > peliculas._id]
  sala_id      ObjectId [ref: > salas._id]
  complejo_id  ObjectId [ref: > complejos._id]
  cadena_id    ObjectId [ref: > cadenas._id]
  fecha        Date
  hora_inicio  String
  hora_fin     String
  formato      String   [note: "2D, 3D, IMAX, etc."]
  idioma       String   [note: "Original subtitulada o doblada"]
  estado       String   [note: "Programada, En Curso, Finalizada o Cancelada"]
  control_asientos Object [note: "Disponibles, Reservados, Vendidos y Porcentaje de Ocupación"]
}

Table horarios [note: "Precisión de horarios de cada función con tipos: Matinee, Regular, Nocturna o Especial.", headerColor: #4A6C8C] {
  _id                    ObjectId [pk]
  funcion_id             ObjectId [ref: > funciones._id]
  pelicula_id            ObjectId [ref: > peliculas._id]
  sala_id                ObjectId [ref: > salas._id]
  fecha_hora_inicio      Date
  hora_finalizacion      Date
  duracion_total_minutos Int
  tipo_funcion           String   [note: "Matinee, Regular, Nocturna o Especial (con cortometrajes y anuncios)"]
}

Table tarifas [note: "Los precios de las entradas cambian dependiendo del día, horario, tipo de sala, complejo y categoría de cliente.", headerColor: #2E8B8B] {
  _id               ObjectId [pk]
  cadena_id         ObjectId [ref: > cadenas._id]
  complejo_id       ObjectId [ref: > complejos._id]
  tipo_sala         String
  dia_semana        String
  franja_horaria    String   [note: "Matinee, Regular, Nocturna o Especial"]
  categoria_cliente String   [note: "Adulto, Niño, Estudiante o Adulto Mayor"]
  precio_base       Float
  impuestos         Float
  precio_total      Float
}

Table asientos [note: "Inventario detallado de asientos con identificación, zona, estado y tipo de butaca para cada sala.", headerColor: #7C2832] {
  _id             ObjectId [pk]
  sala_id         ObjectId [ref: > salas._id]
  fila            String
  numero_butaca   Int
  zona            String   [note: "General, Preferencial o VIP"]
  estado_actual   String   [note: "Disponible, Reservado, Vendido, Bloqueado o En Mantenimiento"]
  precio_asociado Float
  tipo_butaca     String   [note: "Estándar, Reclinable, VIP con Servicio, Doble u otros"]
}

Table clientes [note: "Nuestros queridos clientes registrados, con sus datos de contacto y preferencias.", headerColor: #F5E7C0] {
  _id              ObjectId [pk]
  identificacion   String   [unique, not null]
  nombre_completo  String   [not null]
  correo           String   [unique, not null]
  telefono         String
  fecha_nacimiento Date
  genero           String
  programa_lealtad Object   [note: "Toda la información de fidelidad: cuántos puntos tienen, qué tipo de socio son, sus géneros favoritos y su cine de siempre."]
}

Table reservas [note: "Registro completo de compras o reservas con asientos, estados y datos de pago completos.", headerColor: #E08B2A] {
  _id                ObjectId  [pk]
  cliente_id         ObjectId  [ref: > clientes._id]
  cadena_id          ObjectId  [ref: > cadenas._id]
  complejo_id        ObjectId  [ref: > complejos._id]
  pelicula_id        ObjectId  [ref: > peliculas._id]
  funcion_id         ObjectId  [ref: > funciones._id]
  asientos_apartados Array     [note: "Lista de asientos con IDs y precios unitarios"]
  estado_reserva     String    [note: "Pendiente, Confirmada, Cancelada o Expirada"]
  datos_pago         Object    [note: "Método, número tarjeta, titular, tipo, vencimiento (MM/YY) y entidad bancaria"]
}

Table boletos [note: "El boleto final que se genera tras una reserva exitosa para que la persona pueda entrar a su función.", headerColor: #F6C75A] {
  _id                   ObjectId [pk]
  reserva_id            ObjectId [ref: > reservas._id]
  codigo_verificacion   String   [unique]
  cadena_complejo       String
  titulo_pelicula       String
  fecha_hora_funcion    Date
  sala                  String
  asientos              Array    [note: "Las ubicaciones exactas que compró el cliente, como 'A-10', 'B-12' y 'B-13'."]
  precio_pagado         Float
  cliente_id            ObjectId [ref: > clientes._id]
  marca_temporal_compra Date
  modalidad_entrega     String   [note: "¿El cliente llevará el boleto en su celular o prefiere que se lo impriman en el cine?"]
}

Table promociones [note: "Promociones con restricciones de uso, control de cupones e historial de redención.", headerColor: #C6368A] {
  _id                 ObjectId [pk]
  codigo              String   [unique, not null]
  nombre              String   [not null]
  descripcion         String
  tipo_descuento      String   [note: "Porcentaje o Monto Fijo"]
  valor_descuento     Float    [not null]
  fecha_inicio        Date
  fecha_fin           Date
  estado              String   [note: "Activa, Pausada, Expirada o Agotada"]
  restricciones       Object   [note: "Películas, salas, días, horarios, complejos, solo lealtad"]
  control_uso         Object   [note: "Máximos totales y por cliente, monto mínimo, acumulable"]
  historial_redencion Array    [note: "Registro de usos por cliente: fecha, monto descontado, estado"]
}

