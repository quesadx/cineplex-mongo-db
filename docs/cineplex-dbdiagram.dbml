

Table cadenas [note: "Aquí guardamos la información principal de las grandes cadenas de cines.", headerColor: #1E3A58] {
  _id                ObjectId [pk]
  nombre             String   [not null]
  pais               String
  ciudad_principal   String
  ano_fundacion      Int
  cantidad_complejos Int
}

Table complejos [note: "Estos son los cines físicos concretos que pertenecen a cada cadena en distintas ciudades y distritos.", headerColor: #A63F35] {
  _id              ObjectId [pk]
  nombre           String   [not null]
  cadena_id        ObjectId [ref: > cadenas._id]
  ciudad           String
  distrito         String
  direccion        String
  telefono         String
  cantidad_salas   Int
  estacionamiento  Boolean
}

Table salas [note: "Cada cine tiene varias salas con distintas características, pantallas y sistemas de sonido.", headerColor: #3A3F4B] {
  _id           ObjectId [pk]
  numero_sala   Int      [not null]
  complejo_id   ObjectId [ref: > complejos._id]
  capacidad     Int
  tipo_pantalla String   [note: "Puede ser una pantalla Estándar, 3D, IMAX, entre otras opciones."]
  audio         String   [note: "Por ejemplo, un sonido increíble con Dolby Atmos o el clásico Dolby Digital."]
  disponible    Boolean
}

Table peliculas [note: "Nuestro catálogo completo de películas, con toda la información sobre géneros, directores y sinopsis.", headerColor: #D6A541] {
  _id              ObjectId [pk]
  titulo           String   [not null]
  director         String
  genero           String
  ano_estreno      Int
  duracion_minutos Int
  clasificacion    String
  sinopsis         String
  idioma_original  String
  en_cartelera     Boolean
}


Table funciones [note: "Las funciones o proyecciones que se planean para la semana en un cine y sala específicos.", headerColor: #C84630] {
  _id          ObjectId [pk]
  pelicula_id  ObjectId [ref: > peliculas._id]
  sala_id      ObjectId [ref: > salas._id]
  complejo_id  ObjectId [ref: > complejos._id]
  cadena_id    ObjectId [ref: > cadenas._id]
  fecha        Date
  hora_inicio  String
  hora_fin     String
  formato      String   [note: "Indica en qué formato se proyectará, como 2D, 3D, IMAX, etc."]
  idioma       String   [note: "Nos dice si la película está doblada al espanol o en su idioma original con subtítulos."]
  estado       String   [note: "El estado actual de la función: si está por darse, si ya terminó o si lamentablemente se canceló."]
}

Table horarios [note: "Acá detallamos con precisión a qué hora empieza y termina cada función.", headerColor: #4A6C8C] {
  _id                    ObjectId [pk]
  funcion_id             ObjectId [ref: > funciones._id]
  pelicula_id            ObjectId [ref: > peliculas._id]
  sala_id                ObjectId [ref: > salas._id]
  fecha_hora_inicio      Date
  hora_finalizacion      Date
  duracion_total_minutos Int
  tipo_funcion           String   [note: "Ayuda a saber si es función de matiné, regular, trasnoche o algún evento especial."]
}

Table tarifas [note: "Los precios de las entradas cambian dependiendo del día de la semana y si es para un nino o un adulto.", headerColor: #2E8B8B] {
  _id               ObjectId [pk]
  cadena_id         ObjectId [ref: > cadenas._id]
  tipo_sala         String
  dia_semana        String
  categoria_cliente String   [note: "Diferenciamos el precio si el boleto es para un adulto, nino, estudiante o tarifa preferencial."]
  precio_base       Float
  impuestos         Float
  precio_total      Float
}

Table asientos [note: "El inventario asiento por asiento de cada sala. Acá sabemos si una butaca en específico está libre, reservada o ya se vendió.", headerColor: #7C2832] {
  _id             ObjectId [pk]
  sala_id         ObjectId [ref: > salas._id]
  fila            String
  numero_butaca   Int
  zona            String   [note: "Las distintas zonas dentro de la sala, como general, preferencial o VIP."]
  estado_actual   String   [note: "Nos avisa al instante si te puedes sentar ahí, si alguien ya lo reservó o si ya está comprado."]
  precio_asociado Float
  tipo_butaca     String   [note: "¿Es una butaca normal o una súper cómoda y reclinable?"]
}

Table clientes [note: "Nuestros queridos clientes registrados, con sus datos de contacto y preferencias.", headerColor: #F5E7C0] {
  _id              ObjectId [pk]
  identificacion   String   [unique, not null]
  nombre_completo  String   [not null]
  correo           String   [unique, not null]
  telefono         String
  fecha_nacimiento Date
  genero           String
  programa_lealtad Object   [note: "Toda la información de fidelidad: cuántos puntos tienen, qué tipo de socio son, sus géneros favoritos y su cine de siempre."]
}

Table reservas [note: "El registro de cada compra o reserva que hace un cliente, incluyendo qué asientos eligió y cómo pagó.", headerColor: #E08B2A] {
  _id                ObjectId  [pk]
  cliente_id         ObjectId  [ref: > clientes._id]
  cadena_id          ObjectId  [ref: > cadenas._id]
  complejo_id        ObjectId  [ref: > complejos._id]
  pelicula_id        ObjectId  [ref: > peliculas._id]
  funcion_id         ObjectId  [ref: > funciones._id]
  asientos_apartados Array     [note: "Una lista con todas las butacas seleccionadas en esta reserva y cuánto costó cada una."]
  estado_reserva     String    [note: "Nos dice si la compra ya pasó, si está en espera, si el cliente se arrepintió o si se le pasó el tiempo para pagar."]
  datos_pago         Object    [note: "Con qué tarjeta pagaron, quién es el titular y el método de pago utilizado."]
}

Table boletos [note: "El boleto final que se genera tras una reserva exitosa para que la persona pueda entrar a su función.", headerColor: #F6C75A] {
  _id                   ObjectId [pk]
  reserva_id            ObjectId [ref: > reservas._id]
  codigo_verificacion   String   [unique]
  cadena_complejo       String
  titulo_pelicula       String
  fecha_hora_funcion    Date
  sala                  String
  asientos              Array    [note: "Las ubicaciones exactas que compró el cliente, como 'A-10', 'B-12' y 'B-13'."]
  precio_pagado         Float
  cliente_id            ObjectId [ref: > clientes._id]
  marca_temporal_compra Date
  modalidad_entrega     String   [note: "¿El cliente llevará el boleto en su celular o prefiere que se lo impriman en el cine?"]
}

Table promociones [note: "Todas las promociones, códigos de descuento y ofertas para que los clientes vengan más al cine.", headerColor: #C6368A] {
  _id                 ObjectId [pk]
  codigo              String   [unique, not null]
  nombre              String   [not null]
  descripcion         String
  tipo_descuento      String   [note: "Indica si el descuento te quita un porcentaje del total o si te descuenta una cantidad de dinero específica."]
  valor_descuento     Float    [not null]
  fecha_inicio        Date
  fecha_fin           Date
  estado              String   [note: "¿Aún se puede usar esta promo o ya se acabó el tiempo para aprovecharla?"]
  restricciones       Object   [note: "Las reglas de la promo: en qué películas aplica, qué días no es válida y si es solo para miembros."]
  control_uso         Object   [note: "Límites de la promo: cuántas veces se puede usar, cuánto debe gastar mínimo el cliente y si es acumulable."]
  historial_redencion Array    [note: "El historial de todas las veces que alguien usó este descuento con éxito."]
}

