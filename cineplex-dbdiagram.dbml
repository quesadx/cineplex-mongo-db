

Table cadenas [note: "AVANCE 1 — Cadenas cinematográficas", headercolor: #4D8EFF] {
  _id          ObjectId   [pk, note: "Clave primaria"]
  nombre_comercial String [not null]
  razon_social     String [not null]
  pais_origen      String
  empresa_matriz   String
  tipos_servicio   Array   [note: "Cine convencional, IMAX, 4DX, VIP"]
  fecha_fundacion  Date
  fecha_inicio_CR  Date
  zonas_geograficas Array  [note: "Provincias donde opera"]
  convenios        Array   [note: "Objeto: distribuidora, fecha_inicio, estrenos_mensuales, porcentaje_taquilla, generos, titulos_exclusivos"]
}

Table complejos [note: "AVANCE 1 — Complejos (cines) de cada cadena", headercolor: #4D8EFF] {
  _id                    ObjectId [pk]
  cadena_id              ObjectId [ref: > cadenas._id, note: "FK → cadenas"]
  codigo                 String   [not null, unique]
  nombre                 String   [not null]
  ubicacion_provincia    String
  ubicacion_canton       String
  ubicacion_distrito     String
  ubicacion_direccion    String
  centro_comercial       String   [note: "Nombre del CC o 'Edificio propio'"]
  num_salas              Int
  cap_estacionamiento    Int
  servicio_restaurante   Boolean
  servicio_confiteria    Boolean
  servicio_zona_juegos   Boolean
}

Table salas [note: "AVANCE 1 — Salas dentro de cada complejo", headercolor: #4D8EFF] {
  _id                    ObjectId [pk]
  complejo_id            ObjectId [ref: > complejos._id, note: "FK → complejos"]
  numero_id              Int      [not null]
  nombre                 String
  tipo_sala              String   [note: "Convencional, 3D, IMAX, 4DX, VIP"]
  capacidad_total        Int
  pantalla_ancho_m       Float
  pantalla_alto_m        Float
  pantalla_tipo          String
  sistema_sonido         String   [note: "Dolby Atmos / Dolby Digital"]
  tipo_proyector         String
  fecha_ultima_renovacion Date
  asientos_filas         Int
  asientos_columnas      Int
  zonificacion           Array    [note: "Objeto: zona, filas, precio_extra"]
  espacios_discapacidad  Int
  butacas_reclinables    Boolean
}

Table peliculas [note: "AVANCE 1 — Catálogo de películas", headercolor: #34C759] {
  _id                  ObjectId [pk]
  titulo_original      String   [not null]
  titulo_espanol       String
  sinopsis             String
  duracion_min         Int
  generos              Array    [note: "Acción, Drama, Animación, etc."]
  clasificacion_edad   String   [note: "G, PG, PG-13, R, NC-17"]
  pais_origen          String
  idioma_original      String
  director             Array
  reparto_principal    Array
  casa_productora      String
  distribuidora        String
  fecha_estreno_mundial Date
  fecha_estreno_CR     Date
  estado_cartelera     String   [note: "En exhibición / Próximamente / Retirada"]
  formatos_exhibicion  Array    [note: "2D, 3D, IMAX, 4DX, Subtitulada, Doblada"]
  poster_url           String
  trailer_url          String
  puntuacion_critica   Float
  calificacion_publico Float
}


Table funciones [note: "ENTREGA FINAL — Funciones programadas por semana", headercolor: #34C759] {
  _id          ObjectId [pk]
  pelicula_id  ObjectId [ref: > peliculas._id, note: "FK → peliculas"]
  sala_id      ObjectId [ref: > salas._id,     note: "FK → salas"]
  cadena_id    ObjectId [ref: > cadenas._id,   note: "FK → cadenas"]
  fecha        Date
  hora_inicio  String
  hora_fin     String
  formato      String   [note: "2D, 3D, IMAX, etc."]
  idioma       String   [note: "Subtitulada / Doblada"]
  estado       String   [note: "Activa / Cancelada / Finalizada"]
}

Table horarios [note: "ENTREGA FINAL — Horarios recurrentes de funciones", headercolor: #34C759] {
  _id         ObjectId [pk]
  funcion_id  ObjectId [ref: > funciones._id, note: "FK → funciones"]
  dias_semana Array    [note: "Lunes, Martes, etc."]
  hora_inicio String
  hora_fin    String
  temporada   String   [note: "Regular / Vacaciones / Estreno"]
  activo      Boolean
}

Table tarifas [note: "ENTREGA FINAL — Precios por tipo de sala y día", headercolor: #34C759] {
  _id            ObjectId [pk]
  cadena_id      ObjectId [ref: > cadenas._id, note: "FK → cadenas"]
  tipo_sala      String
  dia_semana     String   [note: "Lunes-Jueves / Viernes / Fin de semana"]
  precio_general Float
  precio_vip     Float
  precio_imax    Float
  descuentos     Array    [note: "Objeto: tipo_descuento, porcentaje"]
}

Table asientos [note: "ENTREGA FINAL — Estado de asientos por función", headercolor: #FF9500] {
  _id        ObjectId [pk]
  sala_id    ObjectId [ref: > salas._id,     note: "FK → salas"]
  funcion_id ObjectId [ref: > funciones._id, note: "FK → funciones"]
  fila       String
  columna    Int
  zona       String   [note: "General / Preferencial / VIP"]
  estado     String   [note: "Disponible / Reservado / Ocupado"]
  es_discapacidad Boolean
}

Table clientes [note: "ENTREGA FINAL — Datos de usuarios del sistema", headercolor: #FF9500] {
  _id               ObjectId [pk]
  nombre            String   [not null]
  apellidos         String   [not null]
  email             String   [unique, not null]
  telefono          String
  fecha_nacimiento  Date
  historial_reservas Array   [note: "Array de ObjectId → reservas"]
}

Table reservas [note: "ENTREGA FINAL — Reservas realizadas por clientes", headercolor: #FF9500] {
  _id              ObjectId [pk]
  cliente_id       ObjectId [ref: > clientes._id,   note: "FK → clientes"]
  funcion_id       ObjectId [ref: > funciones._id,  note: "FK → funciones"]
  asientos_reservados Array  [note: "Array de ObjectId → asientos"]
  fecha_reserva    Date
  estado           String   [note: "Pendiente / Confirmada / Cancelada"]
  total_pagar      Float
  metodo_pago      String
}

Table boletos [note: "ENTREGA FINAL — Boletos emitidos por reserva", headercolor: #FF9500] {
  _id           ObjectId [pk]
  reserva_id    ObjectId [ref: > reservas._id,   note: "FK → reservas"]
  asiento_id    ObjectId [ref: > asientos._id,   note: "FK → asientos"]
  funcion_id    ObjectId [ref: > funciones._id,  note: "FK → funciones"]
  codigo_qr     String   [unique]
  precio_pagado Float
  fecha_emision Date
  estado        String   [note: "Válido / Usado / Anulado"]
}
